# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# URL of the Log-Ingestion-and-Metrics service
METRICS_API_URL=http://localhost:8000

# Claude model to use for all agents
MODEL=claude-sonnet-4-6

# Max tokens per agent call
MAX_TOKENS=2048

# Anomaly thresholds
ERROR_RATE_5XX_THRESHOLD_PCT=5.0
ERROR_RATE_4XX_THRESHOLD_PCT=20.0
LATENCY_P95_THRESHOLD_MS=500.0
LATENCY_P99_THRESHOLD_MS=1000.0
MEMORY_USAGE_THRESHOLD_PCT=80.0

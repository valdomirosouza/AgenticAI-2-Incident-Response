# Shared infrastructure secrets — copy to .env and fill in real values
# NEVER commit .env to git
#
# For Qdrant API key auth: add this line to your .env file (empty = auth disabled):
#   QDRANT__SERVICE__API_KEY=your-strong-key
# and update Knowledge-Base config:
#   QDRANT_API_KEY=your-strong-key

# Redis authentication (empty = no password required — development default)
REDIS_PASSWORD=

# API authentication key shared by all services (empty = auth disabled — development default)
# Set to a strong random string in production: openssl rand -hex 32
API_KEY=

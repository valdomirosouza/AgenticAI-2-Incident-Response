# Redis connection string
REDIS_URL=redis://localhost:6379/0

# Max entries kept in the response times sorted set (used for P50/P95/P99)
RESPONSE_TIME_MAX_ENTRIES=100000

# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info

# Log output format: json | text
LOG_FORMAT=json

# OpenTelemetry service name (appears in traces)
OTEL_SERVICE_NAME=log-ingestion-and-metrics

# OTLP gRPC endpoint for trace export (leave empty to use console exporter)
# Example: http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=

# API authentication (empty = disabled)
API_KEY=
